{
	"name": "buf",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/u29dc/buf.git"
	},
	"scripts": {
		"init---------------------------------": "",
		"prepare": "husky",
		"build--------------------------------": "",
		"build": "cargo build --release && OUT_DIR=\"${BUF_HOME:-${TOOLS_HOME:-$HOME/.tools}/buf}\" && mkdir -p \"$OUT_DIR\" && cp target/release/buf \"$OUT_DIR/buf\"",
		"buf": "./target/release/buf",
		"buf:dev": "cargo run --",
		"check--------------------------------": "",
		"util:format": "cargo fmt --all",
		"util:format:check": "cargo fmt --all -- --check",
		"util:lint": "cargo clippy --all-targets --all-features -- -D warnings",
		"util:types": "cargo check --all-targets --all-features",
		"util:test": "cargo test --all",
		"util:build": "cargo build --release",
		"util:check": "STATUS=0; bun run util:format:check || STATUS=1; bun run util:lint || STATUS=1; bun run util:types || STATUS=1; bun run util:test || STATUS=1; bun run util:build || STATUS=1; exit $STATUS",
		"util:clean": "cargo clean"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.1",
		"@commitlint/config-conventional": "^21.0.1",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.4"
	}
}
